# Porta do serviço
PORT=3001

# JWT — use valores diferentes e longos em produção
JWT_SECRET=change-me-in-production
JWT_REFRESH_SECRET=change-me-refresh-in-production

# Banco de dados (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=chave
DB_PASSWORD=chave_secret
DB_NAME=chave_auth

# CORS — origens permitidas (separadas por vírgula)
CORS_ORIGIN=http://localhost:3000,http://localhost:4001
